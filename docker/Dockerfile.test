FROM python:3.11-slim

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV FLASK_ENV=testing
ENV FLASK_DEBUG=1

# Set work directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    postgresql-client \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements/ requirements/
RUN pip install --no-cache-dir --upgrade pip
RUN pip install --no-cache-dir -r requirements/requirements-test.txt

# Copy application code
COPY . .

# Create non-root user
RUN useradd --create-home --shell /bin/bash appuser
RUN chown -R appuser:appuser /app
USER appuser

# Create test directories
RUN mkdir -p /app/test-results /app/coverage-reports

# Expose port for test server
EXPOSE 3012

# Default test command
CMD ["pytest", "tests/", "-v", "--tb=short", "--cov=.", "--cov-report=html:/app/coverage-reports", "--cov-report=term-missing", "--junitxml=/app/test-results/junit.xml"]