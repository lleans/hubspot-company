# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/hubspot_db
DEV_DATABASE_URL=postgresql://user:password@localhost:5432/hubspot_dev
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5433/test_db
PROD_DATABASE_URL=postgresql://prod_user:prod_password@prod_host:5432/hubspot_prod

# PostgreSQL Configuration for Docker
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=hubspot_db

# Application Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
PORT=3012
LOG_LEVEL=INFO

# HubSpot API Configuration
HUBSPOT_API_TIMEOUT=30
COMPANY_PROPERTIES=name,domain,industry,city,state,country,annualrevenue,numberofemployees,timezone,description,createdate
DEAL_PROPERTIES=dealname,amount,pipeline,dealstage,closedate,createdate

# Performance Configuration
BATCH_SIZE=100
REQUEST_TIMEOUT=30
MAX_RETRIES=3
MAX_WORKER_THREADS=5
THREAD_POOL_SIZE=10


